#!/usr/bin/env node

/**
 * Module dependencies.
 */

var app = require('../app');
var debug = require('debug')('backend:server');
var http = require('http');
const { Server } = require('socket.io'); // 🔥 AJOUT

/**
 * Get port from environment and store in Express.
 */

var port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

/**
 * Create HTTP server.
 */

var server = http.createServer(app);

/**
 * 🔥 NOUVEAU : Initialiser Socket.IO
 */
const io = new Server(server, {
  cors: {
    origin: "*",           // 📱 Mobile compatible
    methods: ["GET", "POST"]
  }
});

//    1) On attache l'instance io à Express via app.set('io')
//    → Cela permet d'accéder à io depuis n'importe quelle route (ex : pour 
//      émettre un événement "list-updated" après une modification en base).
app.set('io', io);

//    2) io.on('connection', ...) est exécuté à chaque nouvelle connexion client.
//    → Chaque utilisateur obtient un socket.id unique.
io.on('connection', (socket) => {
  console.log('✅ Utilisateur connecté:', socket.id);

  // 3) join-list(listId)
  //    → Le client rejoint une "room" spécifique à une liste partagée.
  //    → Ainsi, seuls les utilisateurs concernés reçoivent les mises à jour.
  socket.on('join-list', (listId) => {
    socket.join(`list-${listId}`);
    console.log(`Socket ${socket.id} a rejoint la liste ${listId}`);
  });
  // 4) leave-list(listId)
  //    → Le client quitte la room lorsqu'il n'affiche plus la liste.
  socket.on('leave-list', (listId) => {
    socket.leave(`list-${listId}`);
    console.log(`Socket ${socket.id} a quitté la liste ${listId}`);
  });
  // 5) 🆕 Leave ALL rooms lists
  socket.on("leave-all-lists", () => {
    const rooms = [...socket.rooms].filter(r => r.startsWith("list-"));
    rooms.forEach(room => socket.leave(room));
    console.log(`🚪 ${socket.id} quitte toutes les rooms listes`);
  });
  // Room personnelle — notifie l'utilisateur quand quelqu'un lui partage une liste
  socket.on("join-user", (userId) => {
    socket.join(`user-${userId}`);
  });
  socket.on("leave-user", (userId) => {
    socket.leave(`user-${userId}`);
  });

  // ajouté les 2 socket pour le planning
  socket.on("join-planning", userId => {
    socket.join(`planning-${userId}`);
    console.log(`🟢 Socket ${socket.id} joined planning-${userId}`);
  });

  socket.on("leave-planning", userId => {
    socket.leave(`planning-${userId}`);
    console.log(`🔴 Socket ${socket.id} left planning-${userId}`);
  });

  // 6) disconnect
  //    → Permet de log ou nettoyer si besoin.
  socket.on('disconnect', () => {
    console.log('❌ Utilisateur déconnecté:', socket.id);
  });
});

// Résultat :
// Chaque liste partagée possède son propre canal temps réel ("list-<id>").
// Dès qu'une liste est modifiée, seule la room correspondante reçoit
// l'événement "list-updated", ce qui évite de notifier tous les utilisateurs.
//
// C'est le cœur de la synchronisation en temps réel du shopping list.

/**
 * Listen on provided port, on all network interfaces.
 */

server.listen(port);
server.on('error', onError);
server.on('listening', onListening);

/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  var port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error) {
  if (error.syscall !== 'listen') {
    throw error;
  }

  var bind = typeof port === 'string'
    ? 'Pipe ' + port
    : 'Port ' + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
  var addr = server.address();
  var bind = typeof addr === 'string'
    ? 'pipe ' + addr
    : 'port ' + addr.port;
  debug('Listening on ' + bind);
  console.log('🚀 Serveur démarré sur le port', port);
}